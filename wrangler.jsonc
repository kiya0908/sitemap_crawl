{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sitemap-crawl",
  "compatibility_date": "2026-07-16",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": ["0 0 * * *"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "sitemap-crawl",
      "database_id": "be8ed060-41b0-43d9-a3cc-928ac9a723b9",
      "migrations_dir": "migrations"
    }
  ],
  "secrets": {
    "required": ["OPENROUTER_API_KEY"]
  },
  "vars": {
    "OPENROUTER_MODEL": "deepseek/deepseek-v4-flash",
    "OPENROUTER_SITE_URL": "",  //未来上线后后台真实域名
    "OPENROUTER_APP_NAME": "Sitemap Crawl",
    "AI_PROMPT_VERSION": "seo-analysis-v1"
  }
}
